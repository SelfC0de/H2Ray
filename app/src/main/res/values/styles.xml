<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.H2Ray" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:switchStyle">@style/H2RaySwitch</item>
        <item name="android:windowAnimationStyle">@style/H2RayWindowAnimation</item>
    </style>

    <style name="Theme.H2Ray.Launcher" parent="Theme.H2Ray">
        <item name="android:windowBackground">@drawable/bg_welcome</item>
    </style>

    <style name="H2RayStatLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="H2RayStatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="H2RayNavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
    </style>

    <style name="H2RayNavItemActive" parent="H2RayNavItem">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="H2RaySwitch" parent="@android:style/Widget.Material.CompoundButton.Switch">
        <item name="android:thumbTint">@color/switch_thumb</item>
        <item name="android:trackTint">@color/switch_track</item>
        <item name="android:showText">false</item>
        <item name="android:switchMinWidth">48dp</item>
    </style>

    <style name="H2RayWindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/screen_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/screen_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/screen_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/screen_exit</item>
    </style>

    <style name="H2RayCategoryTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">76dp</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="H2RaySettingsTile" parent="H2RayCategoryTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginStart">5dp</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:layout_marginBottom">5dp</item>
    </style>

    <style name="H2RayServerInput" parent="@android:style/Widget.Material.EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_stat</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="H2RayServerButton" parent="@android:style/Widget.Material.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:backgroundTint">@color/accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/background</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="H2RayServerButtonSecondary" parent="H2RayServerButton">
        <item name="android:backgroundTint">@color/surface_elevated</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
